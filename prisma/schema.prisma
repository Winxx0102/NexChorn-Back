generator client {
  provider = "prisma-client-js"
  //engineType      = "library"
  //  engineType="binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


//usuarios,roles y libros guardados xd

model User {
  id         Int         @id @default(autoincrement())
  email      String      @unique
  name       String
  password   String
  isBlocked  Boolean     @default(false)
  role       Role        @default(USER)
  chronicles chronicles[]
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}


model chronicles{
  id         Int         @id @default(autoincrement())
  title      String
  author     String
  content    String
  createdAt  DateTime    @default(now())
  userId     Int
  user       User        @relation(fields: [userId], references: [id])
}
